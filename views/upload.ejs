<%- include("header.ejs") %>

<div class="container">
    <div class="row">
      <div class="col-md-6 m-auto">
        <h1 class="text-center display-4 my-4">AnonShare</h1>
        <p class="text-center">Share pictures being Anonymous.</p>
        <form action="/upload" method="POST" enctype="multipart/form-data">
          <div class="custom-file mb-3">
            <input type="file" name="file" id="file" class="custom-file-input">
          </div>
          <input type="submit" value="Share" class="btn btn-primary btn-block">
          <a class="btn btn-danger btn-block" href="/logout" role="button">Logout</a>
        </form>
        <hr>
      </div>
    </div>
  </div>

<%- include("footer.ejs") %>
</body>