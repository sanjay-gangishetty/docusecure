<%- include("header.ejs") %>
<style>
  input[type=number]::-webkit-inner-spin-button, 
input[type=number]::-webkit-outer-spin-button { 
  -webkit-appearance: none; 
  margin: 0; 
}
</style>
<div class="container text-center">
  <div class="row">
    <div class="col-md-6 m-auto">
      <h1 class="display-4 my-4">DocuSecure</h1>
      <p>One stop solution to save your Documents.</p>
      <h3>Authenticate</h3>
      <hr> 
<form action="/authenticate" method="POST">
<div class="custom-file mb-3">
    <input type="number" name="Pin" id="pin" class="form-control" placeholder="Enter your 4 digit Secret pin" required>
  </div>
  <input type="submit" value="Authenticate" class="btn btn-primary btn-block">
  <a class="btn btn-danger btn-block" href="/home" role="button">Back</a>
</form>  
</div>
</div>
</div>
<script>
  $('input[type=number]').on('mousewheel', function(e) {
  $(e.target).blur();
});
</script>
<%- include("footer.ejs") %>
